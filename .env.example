# Pin a specific simulator UDID (get it from: xcrun simctl list devices)
# IOS_SIM_DEFAULT_UDID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# Override logical screen width in points (default: auto-detect from device type)
# Useful for older devices or iPads not in the built-in lookup table
# IOS_SIM_DEVICE_WIDTH=393

# Write logs to a file in addition to stderr
# IOS_SIM_LOG_FILE=/tmp/ios_simulator_mcp.log
